                    <img src="/static/img/flyer.jpg" alt="TECTICOM 2026 Flyer" class="img-fluid rounded-bottom" style="max-height: 80vh; object-fit: contain;">
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap Bundle JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- JavaScript logic -->
    <script>
        // Countdown timer implementation
        const fechaEvento = new Date("June 26, 2026 10:00:00").getTime();

        function updateCountdown() {
            const ahora = new Date().getTime();
            const diferencia = fechaEvento - ahora;

            if (diferencia <= 0) {
                document.getElementById("dias").innerHTML = "00";
                document.getElementById("horas").innerHTML = "00";
                document.getElementById("minutos").innerHTML = "00";
                document.getElementById("segundos").innerHTML = "00";
                return;
            }

            const dias = Math.floor(diferencia / (1000 * 60 * 60 * 24));
            const horas = Math.floor((diferencia % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutos = Math.floor((diferencia % (1000 * 60 * 60)) / (1000 * 60));
            const segundos = Math.floor((diferencia % (1000 * 60)) / 1000);

            // Pad numbers with leading zeros if they are single digits
            document.getElementById("dias").innerHTML = String(dias).padStart(2, '0');
            document.getElementById("horas").innerHTML = String(horas).padStart(2, '0');
            document.getElementById("minutos").innerHTML = String(minutos).padStart(2, '0');
            document.getElementById("segundos").innerHTML = String(segundos).padStart(2, '0');
        }

        // Run immediately to avoid showing '00' on load
        updateCountdown();
        // Update every second
        setInterval(updateCountdown, 1000);

        // Registration form submission handler
        function handleRegistration(event) {
            event.preventDefault();
            
            // Highlight success state
            document.getElementById("registrationForm").classList.add("d-none");
            document.getElementById("regSuccessMsg").classList.remove("d-none");
            
            // Optional: reset form after delay and hide modal
            setTimeout(() => {
                const modalEl = document.getElementById('registroModal');
                const modal = bootstrap.Modal.getInstance(modalEl);
                if (modal) {
                    modal.hide();
                }
                // Reset form state for next time
                setTimeout(() => {
                    document.getElementById("registrationForm").reset();
                    document.getElementById("registrationForm").classList.remove("d-none");
                    document.getElementById("regSuccessMsg").classList.add("d-none");
                }, 500);
            }, 3000);
        }
    </script>
</body>
